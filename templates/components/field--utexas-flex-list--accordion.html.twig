{#
/**
 * @file
 * Native, dependency-free UT Drupal Kit Flex List accordion for Moody26.
 *
 * An item becomes a disclosure only when it has both a useful summary and
 * content. Incomplete historical items remain visible without becoming dead
 * controls.
 */
#}
{% set flex_list_items = [] %}
{% for item in items %}
  {% set rendered_title = item.content.header|default('')|render %}
  {% set rendered_body = item.content.body|default('')|render %}
  {% set has_title = rendered_title|striptags|trim is not empty %}
  {% set has_body = rendered_body|striptags|trim is not empty %}
  {% if has_title or has_body %}
    {% set flex_list_items = flex_list_items|merge([{
      attributes: item.attributes,
      body: rendered_body,
      has_body: has_body,
      has_title: has_title,
      title: rendered_title
    }]) %}
  {% endif %}
{% endfor %}
{% set rendered_label = label|default('')|render %}
{% set classes = [
  'field',
  'field--name-' ~ field_name|clean_class,
  'field--type-' ~ field_type|clean_class,
  'field--label-' ~ label_display,
  'utexas-flex-list',
  'formatter-accordion',
  'flex-list',
  'flex-list--accordion'
] %}

{% if flex_list_items %}
  <div{{ attributes.addClass(classes) }}>
    {% if not label_hidden and rendered_label|striptags|trim %}
      <div{{ title_attributes.addClass('flex-list__label') }}>{{ rendered_label }}</div>
    {% endif %}

    <div class="moody-accordion">
      {% for entry in flex_list_items %}
        {% if entry.has_title and entry.has_body %}
          <details{{ entry.attributes.addClass('moody-accordion__item') }}>
            <summary class="moody-accordion__summary">
              <span class="moody-accordion__question">{{ entry.title }}</span>
              <span class="moody-accordion__indicator" aria-hidden="true"></span>
            </summary>
            <div class="moody-accordion__answer">
              <div class="moody-accordion__body">{{ entry.body }}</div>
            </div>
          </details>
        {% else %}
          <div{{ entry.attributes.addClass('flex-list__static-item') }}>
            {% if entry.has_title %}
              <div class="flex-list__term">{{ entry.title }}</div>
            {% endif %}
            {% if entry.has_body %}
              <div class="flex-list__description">{{ entry.body }}</div>
            {% endif %}
          </div>
        {% endif %}
      {% endfor %}
    </div>
  </div>
{% endif %}
