{#
/**
 * @file
 * Theme-owned semantic wrapper for the UTProf Profile Listing block.
 *
 * The provider remains responsible for the listing render array, profile
 * selection, view mode, field output, link attributes, and cache metadata.
 */
#}
{%
  set classes = [
    'block',
    'block-' ~ configuration.provider|clean_class,
    'block-' ~ plugin_id|clean_class,
    'profile-listing',
  ]
%}
{% set component_id = attributes.id|default('') %}
{% set heading_id = component_id ? component_id ~ '-title' : '' %}
{% set rendered_header = content.field_utprof_header|render %}
{% set rendered_listing = listing|render %}
{% set rendered_footer = content.field_utprof_footer|render %}
{% set heading_attributes = title_attributes.addClass('profile-listing__title') %}

{% if label and heading_id %}
  {% set attributes = attributes.setAttribute('aria-labelledby', heading_id) %}
  {% set heading_attributes = heading_attributes.setAttribute('id', heading_id) %}
{% elseif label %}
  {% set attributes = attributes.setAttribute('aria-label', label) %}
{% else %}
  {% set attributes = attributes.setAttribute('aria-label', 'People'|t) %}
{% endif %}

<section{{ attributes.addClass(classes) }}>
  {{ title_prefix }}
  {% if label %}
    <h2{{ heading_attributes }}>{{ label }}</h2>
  {% endif %}
  {{ title_suffix }}

  {% if rendered_header|striptags|trim %}
    <div class="profile-listing__header">{{ rendered_header }}</div>
  {% endif %}

  {{ rendered_listing }}

  {% if rendered_footer|striptags|trim %}
    <div class="profile-listing__footer">{{ rendered_footer }}</div>
  {% endif %}
</section>
