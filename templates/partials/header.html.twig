<header id="moody26-header" class="moody26-header">
  <div class="moody26-container moody26-header__masthead">
    <div class="moody26-header__identity">
      {{ page.header_primary }}
    </div>

    <button
      class="moody26-menu-toggle"
      type="button"
      aria-controls="moody26-primary-navigation"
      aria-expanded="false"
    >
      <span class="moody26-menu-toggle__icon" aria-hidden="true"></span>
      <span class="moody26-menu-toggle__label">{{ 'Menu'|t }}</span>
    </button>

    <div class="moody26-header__actions">
      {% if page.header_secondary %}
        <div class="moody26-header__search">{{ page.header_secondary }}</div>
      {% endif %}
      {% if give_link %}
        <a class="moody26-give button" href="{{ give_link }}">{{ 'Give'|t }}</a>
      {% endif %}
    </div>
  </div>

  <div class="moody26-navigation" id="moody26-primary-navigation" data-moody26-drawer>
    <div class="moody26-container moody26-navigation__inner">
      <div
        class="moody26-navigation__actions"
        data-moody26-mobile-actions
        role="group"
        aria-label="{{ 'Site actions'|t }}"
      ></div>
      {{ page.primary_menu }}
      {% if page.header_tertiary and not header_social_links_mobile %}
        <div class="moody26-navigation__utility">{{ page.header_tertiary }}</div>
      {% endif %}
      {% if header_social_links_mobile %}
        <nav class="moody26-header-social moody26-navigation__social" aria-label="{{ 'Social media'|t }}">
          {{ header_social_links_mobile }}
        </nav>
      {% endif %}
    </div>
  </div>
</header>
