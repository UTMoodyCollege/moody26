<nav{{ attributes.addClass('moody26-primary-nav').setAttribute('aria-label', 'Primary navigation'|t) }}>
  {{ title_prefix }}
  {% if label %}
    <h2{{ title_attributes.addClass(configuration.label_display ? [] : ['visually-hidden']) }}>{{ label }}</h2>
  {% endif %}
  {{ title_suffix }}
  {% block content %}
    {{ content }}
  {% endblock %}
</nav>
